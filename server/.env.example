NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://mongo:27017/aquaveda
JWT_SECRET=replace_with_a_32_plus_character_secret_key
JWT_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
DEFAULT_TENANT_ID=public
SEED_TENANT_ID=public
ADMIN_SEED_EMAIL=admin@aquaveda.com
ADMIN_SEED_PASSWORD=
MEMBER_SEED_EMAIL=member@aquaveda.com
MEMBER_SEED_PASSWORD=
GEMINI_API_KEY=your_gemini_api_key_here
